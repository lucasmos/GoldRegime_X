# Gold Regime X — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git (it's in .gitignore).

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot, follow the prompts, copy the token below
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 3. Send /start to your new bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy the "id" value from "chat" in the first result
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Remote Control Security ───────────────────────────────────────────────────
# Your personal Telegram numeric user ID (not username).
# Only messages from this ID will be accepted by --mode listen.
# Get it from: https://t.me/userinfobot  or the getUpdates response above
ALLOWED_USER_ID=your_telegram_user_id_here

# ── Live Trading Defaults for Remote Control ──────────────────────────────────
# These values are used when you press "START TRADING" from Telegram.
LIVE_TF=H1
LIVE_BROKER=headway_cent
LIVE_BALANCE=15
